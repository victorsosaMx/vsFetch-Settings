        return hdr

    def _make_notebook(self) -> Gtk.Notebook:
        nb = Gtk.Notebook()
        self._notebook = nb
        nb.set_tab_pos(Gtk.PositionType.LEFT)
        nb.set_show_border(False)
        for name, builder in [
            ("  Templates ", self._page_templates),
            ("  Palette   ", self._page_palette),
