    def _make_tpl_card(self, name: str, tpl: dict) -> Gtk.Widget:
        pal  = tpl["palette"]
        bg   = pal["bg"]
        txt  = pal["text"]
        acc  = pal["accent"]
        anim = tpl["animation"]

        # per-card background + active highlight via dedicated provider
        is_active = (name == self._loaded_tpl)
        cls       = "tc" + re.sub(r'[^A-Za-z0-9]', '', name)
        provider  = Gtk.CssProvider()
        if is_active:
            provider.load_from_data(
                f".{cls} {{ background-color: {bg}; border: 3px solid {acc}; }}".encode()
            )
        else:
            provider.load_from_data(
                f".{cls} {{ background-color: {bg}; }}".encode()
            )

        card = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=6)
        card.set_size_request(280, -1)
        card.get_style_context().add_class("tpl-card")
        card.get_style_context().add_class(cls)
        card.get_style_context().add_provider(
            provider, Gtk.STYLE_PROVIDER_PRIORITY_APPLICATION + 1
        )

        # template name
        name_lbl = Gtk.Label()
        name_lbl.set_markup(
            f'<span foreground="{txt}" weight="bold" size="13500">'
            f'{GLib.markup_escape_text(name)}</span>'
        )
        name_lbl.set_xalign(0)
        name_lbl.set_line_wrap(True)
        card.pack_start(name_lbl, False, False, 0)

        # description line
