    def _export_theme(self, *_):
        """Export aesthetic keys as a shareable theme file, user picks what to include."""
        self._collect()

        dlg = Gtk.Dialog(title="Export Theme", parent=self,
                         flags=Gtk.DialogFlags.MODAL)
        dlg.set_default_size(400, -1)
        area = dlg.get_content_area()
        area.set_spacing(4)
        area.set_border_width(20)

        hdr = Gtk.Label()
        hdr.set_markup(f'<b>Select what to include in the exported theme</b>')
        hdr.set_xalign(0)
        area.pack_start(hdr, False, False, 0)

        hint_lbl = Gtk.Label(label="Uncheck personal/machine-specific keys before sharing.")
        hint_lbl.set_xalign(0)
        hint_lbl.get_style_context().add_class("hint-label")
        hint_lbl.set_margin_top(4)
        hint_lbl.set_margin_bottom(12)
        area.pack_start(hint_lbl, False, False, 0)

        GROUPS = [
            ("palette",      "Palette  (colors)",                  True),
            ("animation",    "Animation",                          True),
            ("gradient_bar", "Gradient bar",                       True),
            ("layout",       "Layout  (top / left)",               True),
            ("font",         "Font family",                        True),
            ("font_sizes",   "Font sizes",                         True),
            ("logo",         "Logo settings",                      True),
            ("window",       "Window dimensions",                  True),
            ("default_mode", "Default mode",                       True),
            ("sections",     "Sections & order  (personal)",       False),
            ("dev_tools",    "Dev tools list  (personal)",         False),
            ("bg_image",     "Background image  (has your path!)", False),
            ("extends",      "Extends reference",                  False),
            ("chassis",      "Chassis label  (personal)",          False),
        ]
        checks = {}
        for key, label, default in GROUPS:
            cb = Gtk.CheckButton(label=label)
            cb.set_active(default)
            checks[key] = cb
            area.pack_start(cb, False, False, 2)

        toggle_row = Gtk.Box(spacing=8)
        toggle_row.set_margin_top(10)
        all_btn = Gtk.Button(label="Select all")
        none_btn = Gtk.Button(label="Deselect all")
        def _select_all(*_):
            for cb in checks.values(): cb.set_active(True)
        def _select_none(*_):
            for cb in checks.values(): cb.set_active(False)
        all_btn.connect("clicked", _select_all)
        none_btn.connect("clicked", _select_none)
        toggle_row.pack_start(all_btn,  False, False, 0)
        toggle_row.pack_start(none_btn, False, False, 0)
        area.pack_start(toggle_row, False, False, 0)

        dlg.add_button("Cancel",   Gtk.ResponseType.CANCEL)
        dlg.add_button("Export…",  Gtk.ResponseType.OK)
        dlg.set_default_response(Gtk.ResponseType.OK)
        dlg.show_all()

        if dlg.run() != Gtk.ResponseType.OK:
            dlg.destroy()
            return

        selected = {k for k, cb in checks.items() if cb.get_active()}
        dlg.destroy()

        out = {"extends": ""}
        SCALAR = {"layout", "font", "default_mode", "chassis", "extends"}
        for key in selected:
            if key in SCALAR:
                out[key] = self._cfg.get(key, "")
            else:
                out[key] = copy.deepcopy(self._cfg[key])

        fc = Gtk.FileChooserDialog(
            title="Export theme as…", parent=self,
            action=Gtk.FileChooserAction.SAVE,
            buttons=("Cancel", Gtk.ResponseType.CANCEL,
                     "Export",  Gtk.ResponseType.OK),
        )
        fc.set_do_overwrite_confirmation(True)
        themes_dir = os.path.expanduser("~/.config/vsfetch/themes")
        fc.set_current_folder(themes_dir if os.path.isdir(themes_dir)
                              else os.path.dirname(self._config_path))
        fc.set_current_name("my-theme.json")
        ff = Gtk.FileFilter()
        ff.set_name("JSON theme")
        ff.add_pattern("*.json")
        fc.add_filter(ff)

        if fc.run() == Gtk.ResponseType.OK:
            path = fc.get_filename()
            fc.destroy()
            os.makedirs(os.path.dirname(path), exist_ok=True)
            try:
                with open(path, "w") as f:
                    json.dump(out, f, indent=2, ensure_ascii=False)
                self._status(
                    f"✓  Theme exported  →  {path}",
                    '·  Use it with:  "extends": "' + path + '"',
                )
            except Exception as e:
                self._err(f"Could not export:\n{e}")
        else:
            fc.destroy()

    def _apply_template(self, tpl: dict) -> dict:
        """Merge template aesthetics over current personal config."""
        saved = {k: copy.deepcopy(self._cfg[k]) for k in
                 ("bg_image", "extends", "chassis", "dev_tools", "sections")}
        merged = copy.deepcopy(tpl)
        merged.update(saved)
        return merged

