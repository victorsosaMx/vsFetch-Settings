# ── main window ───────────────────────────────────────────────────────────────

class VsFetchSettings(Gtk.Window):

    def __init__(self):
        super().__init__(title="vsFetch Settings")
        self.set_default_size(900, 640)
        self.set_position(Gtk.WindowPosition.CENTER)
        self.connect("delete-event", self._on_close)
        self.connect("key-press-event", self._on_key)

        self._config_path = os.path.expanduser("~/.config/vsfetch/config.json")
        self._cfg: dict   = {}
        self._w:   dict   = {}

        self._dark          = False
        self._theme         = THEME_LIGHT
        self._css_provider  = Gtk.CssProvider()
        self._loaded_tpl    = None
        self._dirty         = False
        self._path_lbl      = None
        self._status_timer  = None

        Gtk.StyleContext.add_provider_for_screen(
            Gdk.Screen.get_default(),
            self._css_provider,
            Gtk.STYLE_PROVIDER_PRIORITY_APPLICATION,
        )
        self._apply_css()
        self._load_config()
        self._build_ui()
        self.show_all()
        self._clear_dirty()

    # ── window-level events ───────────────────────────────────────────────────

    def _on_close(self, *_):
        if not self._confirm_discard("Quit"):
            return True   # block close
        Gtk.main_quit()
        return False

    def _on_key(self, _, event):
        ctrl = event.state & Gdk.ModifierType.CONTROL_MASK
        if ctrl:
            if event.keyval == Gdk.KEY_s: self._save();     return True
            if event.keyval == Gdk.KEY_o: self._on_open();  return True
            if event.keyval == Gdk.KEY_r: self._on_reset(); return True
        return False

    # ── CSS ───────────────────────────────────────────────────────────────────

    def _apply_css(self):
        self._css_provider.load_from_data(_build_css(self._theme))

    def _toggle_theme(self, *_):
        was_dirty = self._dirty
        self._dark  = not self._dark
        self._theme = THEME_DARK if self._dark else THEME_LIGHT
        self._apply_css()
        self._rebuild_ui()
        if was_dirty:
            self._mark_dirty()
        else:
            self._clear_dirty()

    # ── config I/O ────────────────────────────────────────────────────────────

    def _load_config(self):
        self._cfg = copy.deepcopy(DEFAULTS)
        try:
            with open(self._config_path) as f:
                user = json.load(f)
            for s in ("palette", "font_sizes", "logo", "window",
                      "gradient_bar", "bg_image", "animation"):
                if s in user:
                    self._cfg[s].update(user[s])
            for k in ("font", "default_mode", "layout", "sections",
                      "chassis", "dev_tools", "extends"):
                if k in user:
                    self._cfg[k] = user[k]
        except FileNotFoundError:
            pass
        except Exception as e:
            self._err(f"Could not load config:\n{e}")

    def _collect(self):
        w = self._w

        for key, btn in w.get("palette", {}).items():
            self._cfg["palette"][key] = _rgba_to_hex(btn.get_rgba())

        if "font" in w:
            raw  = w["font"].get_font_name()
            desc = Pango.font_description_from_string(raw)
            self._cfg["font"] = desc.get_family() or raw

        for k in ("title", "body", "small"):
            if f"fs_{k}" in w:
                self._cfg["font_sizes"][k] = int(w[f"fs_{k}"].get_value())

        for key in ("layout", "default_mode"):
            if key in w:
                self._cfg[key] = w[key].get_active_text()
        for key in ("chassis", "extends"):
            if key in w:
                self._cfg[key] = w[key].get_text().strip()

        if "sections_store" in w:
            self._cfg["sections"] = [row[0] for row in w["sections_store"] if row[1]]

        if "devtools_store" in w:
            self._cfg["dev_tools"] = [
                {"icon": row[0], "name": row[1], "cmd": row[2]}
                for row in w["devtools_store"]
            ]

        for k in ("width", "height_full", "height_mini"):
            if f"win_{k}" in w:
                self._cfg["window"][k] = int(w[f"win_{k}"].get_value())

        if "logo_size"       in w: self._cfg["logo"]["size"]             = int(w["logo_size"].get_value())
        if "logo_override"   in w: self._cfg["logo"]["override"]         = w["logo_override"].get_text().strip()
        if "logo_sidebar_pos"in w: self._cfg["logo"]["sidebar_position"] = w["logo_sidebar_pos"].get_active_text()

        if "gb_enabled" in w: self._cfg["gradient_bar"]["enabled"] = w["gb_enabled"].get_active()
        for k in ("color_a", "color_b"):
            if f"gb_{k}" in w:
                self._cfg["gradient_bar"][k] = _rgba_to_hex(w[f"gb_{k}"].get_rgba())

        if "bgi_enabled" in w: self._cfg["bg_image"]["enabled"] = w["bgi_enabled"].get_active()
        if "bgi_path"    in w: self._cfg["bg_image"]["path"]    = w["bgi_path"].get_text().strip()
        if "bgi_size"    in w: self._cfg["bg_image"]["size"]    = int(w["bgi_size"].get_value())
        if "bgi_opacity" in w: self._cfg["bg_image"]["opacity"] = round(w["bgi_opacity"].get_value(), 2)

        if "anim_enabled" in w: self._cfg["animation"]["enabled"] = w["anim_enabled"].get_active()
        if "anim_type"    in w: self._cfg["animation"]["type"]    = w["anim_type"].get_active_text()
        if "anim_scope"   in w: self._cfg["animation"]["scope"]   = w["anim_scope"].get_active_text()
        if "anim_color"   in w: self._cfg["animation"]["color"]   = w["anim_color"].get_text().strip()
        for akey, digits in (("opacity", 2), ("speed", 2), ("drops", 0)):
            wkey = f"anim_{akey}"
            if wkey in w:
                val = w[wkey].get_value()
                self._cfg["animation"][akey] = round(val, digits) if digits else int(val)

    def _save(self, *_):
        dlg = Gtk.FileChooserDialog(
            title="Save config as…", parent=self,
            action=Gtk.FileChooserAction.SAVE,
            buttons=("Cancel", Gtk.ResponseType.CANCEL, "Save", Gtk.ResponseType.OK),
        )
        dlg.set_do_overwrite_confirmation(True)
        dlg.set_current_folder(os.path.dirname(self._config_path))
        dlg.set_current_name(os.path.basename(self._config_path))
        ff = Gtk.FileFilter()
        ff.set_name("JSON configs")
        ff.add_pattern("*.json")
        dlg.add_filter(ff)
        if dlg.run() == Gtk.ResponseType.OK:
            path = dlg.get_filename()
            dlg.destroy()
            self._collect()
            os.makedirs(os.path.dirname(path), exist_ok=True)
            try:
                with open(path, "w") as f:
                    json.dump(self._cfg, f, indent=2, ensure_ascii=False)
                self._config_path = path
                self._clear_dirty()
                self._status(f"✓  Saved  →  {path}")
            except Exception as e:
                self._err(f"Could not save:\n{e}")
        else:
            dlg.destroy()

    # ── UI skeleton ───────────────────────────────────────────────────────────

    def _rebuild_ui(self):
        """Save notebook page, strip children, rebuild, restore page."""
        page = self._notebook.get_current_page()
        for child in self.get_children():
            self.remove(child)
        self._build_ui()
        self._notebook.set_current_page(page)
        self.show_all()

    def _build_ui(self):
        self._w = {}
        root = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=0)
        self.add(root)
        root.pack_start(self._make_header(),   False, False, 0)
        root.pack_start(self._make_notebook(), True,  True,  0)
        root.pack_start(self._make_statusbar(), False, False, 0)
        self._connect_dirty_signals()

    def _make_statusbar(self) -> Gtk.Widget:
        bar = Gtk.Box(spacing=10)
        bar.get_style_context().add_class("status-bar")

        self._status_lbl  = Gtk.Label(label="")
        self._status_lbl.set_xalign(0)
        self._status_lbl.get_style_context().add_class("status-ok")

        self._status_hint = Gtk.Label(label="")
        self._status_hint.set_xalign(0)
        self._status_hint.get_style_context().add_class("status-hint")

        bar.pack_start(self._status_lbl,  False, False, 0)
        bar.pack_start(self._status_hint, False, False, 0)
        return bar

    def _status(self, main: str, hint: str = "", timeout: int = 6000):
        self._status_lbl.set_text(main)
        self._status_hint.set_text(hint)
        if self._status_timer:
            GLib.source_remove(self._status_timer)
        def _clear():
            self._status_lbl.set_text("")
            self._status_hint.set_text("")
            self._status_timer = None
            return False
        self._status_timer = GLib.timeout_add(timeout, _clear)

    def _make_header(self) -> Gtk.Widget:
        hdr = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=0)
        hdr.get_style_context().add_class("app-header")

        left = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=3)
        left.set_valign(Gtk.Align.CENTER)
        left.pack_start(_lbl("󰒓  vsFetch Settings", "app-title"), False, False, 0)
        self._path_lbl = _lbl(self._config_path, "app-path")
        left.pack_start(self._path_lbl, False, False, 0)
        hdr.pack_start(left, True, True, 0)

        btn_box = Gtk.Box(spacing=8)
        btn_box.set_valign(Gtk.Align.CENTER)

        theme_btn = Gtk.Button(label="☾" if self._dark else "☀")
        theme_btn.get_style_context().add_class("theme-btn")
        theme_btn.set_tooltip_text("Switch to light mode" if self._dark else "Switch to dark mode")
        theme_btn.connect("clicked", self._toggle_theme)

        reset_btn = Gtk.Button(label="↺")
        reset_btn.get_style_context().add_class("open-btn")
        reset_btn.set_tooltip_text("Reset to defaults (Catppuccin Mocha)")
        reset_btn.connect("clicked", self._on_reset)

        open_btn = Gtk.Button(label="Open…")
        open_btn.get_style_context().add_class("open-btn")
        open_btn.connect("clicked", self._on_open)

        save_btn = Gtk.Button(label="Save As…")
        save_btn.get_style_context().add_class("save-btn")
        save_btn.connect("clicked", self._save)

        preview_btn = Gtk.Button(label="Preview")
        preview_btn.get_style_context().add_class("open-btn")
        preview_btn.set_tooltip_text("Launch vsFetch with current (unsaved) settings")
        preview_btn.connect("clicked", self._preview)

        export_btn = Gtk.Button(label="Export…")
        export_btn.get_style_context().add_class("open-btn")
        export_btn.set_tooltip_text("Export current settings as a shareable theme file")
        export_btn.connect("clicked", self._export_theme)

        btn_box.pack_start(theme_btn,   False, False, 0)
        btn_box.pack_start(reset_btn,   False, False, 0)
        btn_box.pack_start(preview_btn, False, False, 0)
        btn_box.pack_start(open_btn,    False, False, 0)
        btn_box.pack_start(export_btn,  False, False, 0)
        btn_box.pack_start(save_btn,    False, False, 0)
