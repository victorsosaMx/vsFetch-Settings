    def _apply_matugen_colors(self, colors: dict, source_label: str):
        """Map parsed matugen color dict onto the palette ColorButtons."""
        palette_btns = self._w.get("palette", {})
        applied = 0
        for vsf_key, m3_role in _MATUGEN_MAP.items():
            if vsf_key not in palette_btns:
                continue
            try:
                hex_val = colors[m3_role]["default"]["color"]
                palette_btns[vsf_key].set_rgba(_hex_to_rgba(hex_val))
                applied += 1
            except (KeyError, TypeError):
                pass
        self._status(
            f"{source_label}  ({applied}/14 colors)",
            "·  Review colors above  ·  Save As… to keep",
        )

    def _wire_path_validation(self, entry: Gtk.Entry):
        """Highlight entry red when the typed path doesn't exist on disk."""
        def _validate(*_):
            p = entry.get_text().strip()
            p = os.path.expanduser(p)
            ok = (p == "") or os.path.exists(p)
            ctx = entry.get_style_context()
            if ok:
                ctx.remove_class("entry-error")
            else:
                ctx.add_class("entry-error")
        entry.connect("changed", _validate)
        _validate()

    def _load_palette_from_image(self, *_):
        """Run matugen on a chosen image and map Material You colors to the palette."""
        if not shutil.which("matugen"):
            self._err("matugen not found.\n\nInstall it with:\n  yay -S matugen")
            return
        img = _file_chooser(self, "Select image for palette extraction",
                            mime_types=["image/png", "image/jpeg", "image/webp",
                                        "image/jpg", "image/bmp"])
        if not img:
            return
        mode = self._rnd_mode.get_active_id()
        try:
            result = subprocess.run(
                ["matugen", "image", img, "-m", mode, "-j", "hex",
                 "--source-color-index", "0", "--dry-run"],
                capture_output=True, text=True, timeout=15,
            )
            if result.returncode != 0:
                result = subprocess.run(
                    ["matugen", "image", img, "-m", mode, "-j", "hex",
                     "--source-color-index", "0"],
                    capture_output=True, text=True, timeout=15,
                )
            colors = json.loads(result.stdout)["colors"]
        except Exception as e:
            self._err(f"matugen failed:\n{e}")
            return
        self._apply_matugen_colors(colors, "󰸉  Palette extracted from image")

    def _load_palette_from_color(self, *_):
        """Run matugen on a single hex color and map Material You colors to palette."""
        if not shutil.which("matugen"):
            self._err("matugen not found.\n\nInstall it with:\n  yay -S matugen")
            return
        dlg = Gtk.ColorChooserDialog(title="Pick a base color", parent=self)
        if dlg.run() != Gtk.ResponseType.OK:
            dlg.destroy()
            return
        rgba = dlg.get_rgba()
        dlg.destroy()
        hex_color = _rgba_to_hex(rgba)
        mode = self._rnd_mode.get_active_id()
        try:
            result = subprocess.run(
                ["matugen", "color", "hex", hex_color,
                 "-m", mode, "-j", "hex", "--dry-run"],
                capture_output=True, text=True, timeout=15,
            )
            colors = json.loads(result.stdout)["colors"]
        except Exception as e:
            self._err(f"matugen failed:\n{e}")
            return
        self._apply_matugen_colors(colors, f"  Palette from {hex_color}")

