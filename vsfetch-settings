            model, it = tv.get_selection().get_selected()
            if not it:
                return
            if d < 0:
                prev = model.iter_previous(it)
                if prev: model.move_before(it, prev)
            else:
                nxt = model.iter_next(it)
                if nxt:  model.move_after(it, nxt)

        up_btn = Gtk.Button(label="↑  Move Up")
        up_btn.connect("clicked", lambda *_: _move(-1))
        dn_btn = Gtk.Button(label="↓  Move Down")
        dn_btn.connect("clicked", lambda *_: _move(1))
        btn_row.pack_start(up_btn, False, False, 0)
        btn_row.pack_start(dn_btn, False, False, 0)
        box.pack_start(btn_row, False, False, 0)

