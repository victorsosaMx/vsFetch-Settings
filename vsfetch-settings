    # ── dirty tracking ────────────────────────────────────────────────────────

    def _mark_dirty(self, *_):
        if not self._dirty:
            self._dirty = True
            if self._path_lbl:
                self._path_lbl.set_text(self._config_path + "  ●")

    def _clear_dirty(self):
        self._dirty = False
        if self._path_lbl:
            self._path_lbl.set_text(self._config_path)

    def _confirm_discard(self, verb: str) -> bool:
        """Returns True if safe to proceed (clean state or user confirmed)."""
        if not self._dirty:
            return True
        dlg = Gtk.MessageDialog(
            parent=self, flags=Gtk.DialogFlags.MODAL,
            message_type=Gtk.MessageType.WARNING,
            buttons=Gtk.ButtonsType.NONE,
            text="Unsaved changes",
        )
        dlg.format_secondary_text(f"You have unsaved changes. {verb} anyway?")
        dlg.add_button("Cancel",  Gtk.ResponseType.CANCEL)
        dlg.add_button(verb,      Gtk.ResponseType.OK)
        dlg.set_default_response(Gtk.ResponseType.CANCEL)
        resp = dlg.run()
        dlg.destroy()
        return resp == Gtk.ResponseType.OK

    def _connect_dirty_signals(self):
        """Connect change signals on all widgets to _mark_dirty."""
        w = self._w
        for btn in w.get("palette", {}).values():
            btn.connect("color-set", self._mark_dirty)
        if "font" in w:
            w["font"].connect("font-set", self._mark_dirty)
        for key in ("fs_title", "fs_body", "fs_small",
                    "win_width", "win_height_full", "win_height_mini",
                    "logo_size", "bgi_size", "bgi_opacity",
                    "anim_opacity", "anim_speed", "anim_drops"):
            if key in w:
                w[key].connect("value-changed", self._mark_dirty)
        for key in ("layout", "default_mode", "logo_sidebar_pos",
                    "anim_type", "anim_scope"):
            if key in w:
                w[key].connect("changed", self._mark_dirty)
        for key in ("chassis", "extends", "logo_override", "bgi_path", "anim_color"):
            if key in w:
                w[key].connect("changed", self._mark_dirty)
        for key in ("anim_enabled", "gb_enabled", "bgi_enabled"):
            if key in w:
                w[key].connect("notify::active", self._mark_dirty)
        for key in ("gb_color_a", "gb_color_b"):
            if key in w:
                w[key].connect("color-set", self._mark_dirty)
        for store_key in ("sections_store", "devtools_store"):
            if store_key in w:
                for sig in ("row-changed", "row-inserted", "row-deleted"):
                    w[store_key].connect(sig, self._mark_dirty)

    def _on_reset(self, *_):
        if not self._confirm_discard("Reset"):
            return
        self._cfg        = copy.deepcopy(DEFAULTS)
        self._loaded_tpl = None
        self._rebuild_ui()
        self._clear_dirty()
        self._status("↺  Reset to defaults", "·  Catppuccin Mocha  ·  Save As… to keep it")

    def _on_open(self, *_):
        if not self._confirm_discard("Open"):
            return
        p = _file_chooser(self, "Open vsFetch config", patterns=["*.json"])
        if not p:
            return
        self._config_path = p
        self._load_config()
        self._rebuild_ui()
        self._clear_dirty()
        self._status(f"✓  Opened  {p}")

    def _err(self, msg: str):
        dlg = Gtk.MessageDialog(parent=self, flags=Gtk.DialogFlags.MODAL,
                                message_type=Gtk.MessageType.ERROR,
                                buttons=Gtk.ButtonsType.OK, text=msg)
        dlg.run(); dlg.destroy()


