    def _preview_cfg(self, cfg: dict):
        vsfetch = _find_vsfetch()
        if not vsfetch:
            self._err("vsfetch not found.\n\nInstall it via AUR or run from the project directory.")
            return
        tmp = tempfile.NamedTemporaryFile(
            suffix=".json", prefix="vsfetch_preview_", delete=False, mode="w"
        )
        json.dump(cfg, tmp, indent=2, ensure_ascii=False)
        tmp.close()
        try:
            subprocess.Popen(
                ["python3", vsfetch, "--config", tmp.name],
                stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL,
            )
            GLib.timeout_add(3000, lambda: (os.unlink(tmp.name), False)[1])
        except Exception as e:
            os.unlink(tmp.name)
            self._err(f"Could not launch vsfetch:\n{e}")

    def _load_template(self, name: str):
        if not self._confirm_discard("Load template"):
            return
        scroll = 0
        if hasattr(self, "_templates_sw"):
            scroll = self._templates_sw.get_vadjustment().get_value()
        page = self._notebook.get_current_page() if hasattr(self, "_notebook") else 0

        self._loaded_tpl = name
        self._cfg = self._apply_template(TEMPLATES[name])
        self._rebuild_ui()
        self._clear_dirty()

        GLib.idle_add(lambda: (
            self._templates_sw.get_vadjustment().set_value(scroll), False
        )[1])

        self._status(
            f"✓  {name}",
            "·  Preview to see it live  ·  customize in the tabs  ·  Save As… to keep it",
        )

