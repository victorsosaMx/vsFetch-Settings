# ── helpers ───────────────────────────────────────────────────────────────────

def _hex_to_rgba(h: str) -> Gdk.RGBA:
    h = h.lstrip("#")
    c = Gdk.RGBA()
    c.red   = int(h[0:2], 16) / 255
    c.green = int(h[2:4], 16) / 255
    c.blue  = int(h[4:6], 16) / 255
    c.alpha = 1.0
    return c

def _rgba_to_hex(c: Gdk.RGBA) -> str:
    return "#{:02x}{:02x}{:02x}".format(
        round(c.red * 255), round(c.green * 255), round(c.blue * 255)
    )

def _hsv_to_hex(hue: float, s: float, v: float) -> str:
    r, g, b = colorsys.hsv_to_rgb(hue % 1.0, s, v)
    return "#{:02x}{:02x}{:02x}".format(round(r*255), round(g*255), round(b*255))

def _lbl(text: str, style: str = "field-label", xalign: float = 0.0) -> Gtk.Label:
    w = Gtk.Label(label=text)
    w.set_xalign(xalign)
    w.get_style_context().add_class(style)
    return w

def _section(text: str) -> Gtk.Label:
    return _lbl(text.upper(), "section-title")

def _hint(text: str) -> Gtk.Label:
    l = _lbl(text, "hint-label")
    l.set_margin_bottom(10)
    return l

def _color_btn(hex_color: str) -> Gtk.ColorButton:
    btn = Gtk.ColorButton()
    btn.set_rgba(_hex_to_rgba(hex_color))
    btn.set_title("Pick Color")
    return btn

def _spin(value, lo, hi, step=1, digits=0) -> Gtk.SpinButton:
    adj = Gtk.Adjustment(value=value, lower=lo, upper=hi,
                         step_increment=step, page_increment=step * 10)
    sb = Gtk.SpinButton(adjustment=adj, digits=digits)
    sb.set_numeric(True)
    return sb

def _combo(options: list, active: str) -> Gtk.ComboBoxText:
    cb = Gtk.ComboBoxText()
    for o in options:
        cb.append_text(o)
    cb.set_active(options.index(active) if active in options else 0)
    return cb

def _scrolled(child: Gtk.Widget) -> Gtk.ScrolledWindow:
    sw = Gtk.ScrolledWindow()
    sw.set_policy(Gtk.PolicyType.NEVER, Gtk.PolicyType.AUTOMATIC)
    sw.get_style_context().add_class("page-scroll")
    sw.add(child)
    return sw

def _find_vsfetch() -> str | None:
    """Locate the vsfetch executable: PATH first, then relative to this script."""
    p = shutil.which("vsfetch")
    if p:
        return p
    here = os.path.dirname(os.path.abspath(__file__))
    rel  = os.path.normpath(os.path.join(here, "..", "vsFetch", "vsfetch"))
    return rel if os.path.isfile(rel) else None

def _file_chooser(parent, title, patterns=None, mime_types=None) -> str | None:
    dlg = Gtk.FileChooserDialog(
        title=title, parent=parent,
        action=Gtk.FileChooserAction.OPEN,
        buttons=("Cancel", Gtk.ResponseType.CANCEL, "Open", Gtk.ResponseType.OK),
    )
    if patterns or mime_types:
        ff = Gtk.FileFilter()
        ff.set_name("Allowed files")
        for p in (patterns or []):
            ff.add_pattern(p)
        for m in (mime_types or []):
            ff.add_mime_type(m)
        dlg.add_filter(ff)
    path = dlg.get_filename() if dlg.run() == Gtk.ResponseType.OK else None
    dlg.destroy()
    return path

