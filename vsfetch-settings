            ("  Sections  ", self._page_sections),
            ("  Dev Tools ", self._page_devtools),
            ("  Window    ", self._page_window),
            ("  Effects   ", self._page_effects),
            ("  General   ", self._page_general),
            ("  About     ", self._page_about),
        ]:
            tab = _lbl(name)
            tab.set_xalign(0)
            nb.append_page(builder(), tab)
        return nb

